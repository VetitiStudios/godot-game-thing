    {
      "id": "JWhqfxV9bJHtHJOjLV7Ey",
      "type": "text",
      "x": 1469.242693031461,
      "y": -56.482395716213624,
      "width": 290.3333435058594,
      "height": 428.2501179495848,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 1663613341,
      "version": 2125,
      "versionNonce": 1334759421,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773002057601,
      "link": null,
      "locked": false,
      "text": "--------------------BOOLEANS--------------------\nGROUNDED = ? (exactly what you think, colliding\nwith the ground)\nWALL_COLLIDE = ? (colliding with a wall)\nIS_MOVING = ? (exactly as it says)\nIS_DASHING = ? (exactly as it says)\nIS_JUMPING = ? (exactly as it says)\nCAN_WALL_JUMP = ? (exactly as it says)\nIS_FALLING = ? (exactly as it says)\n--------------------NUMBERS---------------------\nSPEED = ? (mutable, used to apply force in the \ndirection player wants)\nMAX_SPEED = 5.0 (the \"max\" speed, player can go \nabove, only matters for friction)\nACCELERATION = 5.0 (adds to speed when player is\nunder \"max\" speed, only applies when player is\nGROUNDED)\nDASH_SPEED = 15.0 (adds to the speed when called)\nJUMP_HEIGHT = 5.0 (how heigh the player can jump)\nFRICTION = 2.5 (increases by 1/5 of your speed \nwhen player is NOT accelerating, resets when \nplayer moves or is at 0 speed, only applies when\nplayer is ABOVE MAX_SPEED AND on ground)\nFRICTION_DELAY = 0.5 (how long on ground until\nfriction applies)\nGRAVITY = 2.5 (increases by .05 AFTER jumping \nevery .5 sec is finished, resets on first \ncollision with wall or grounded)\nWALL_JUMP_ANGLE = ? (reverses players view angle\nto wall to apply opposite when jumping to jump\nAWAY from wall)\nREMAINING_WALL_JUMPS = 3 (remove one per wall jump,\nif at 0 set CAN_WALL_JUMP to false else true, reset \nwhen ground collision)",
      "fontSize": 10.076473363519643,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "--------------------BOOLEANS--------------------\nGROUNDED = ? (exactly what you think, colliding\nwith the ground)\nWALL_COLLIDE = ? (colliding with a wall)\nIS_MOVING = ? (exactly as it says)\nIS_DASHING = ? (exactly as it says)\nIS_JUMPING = ? (exactly as it says)\nCAN_WALL_JUMP = ? (exactly as it says)\nIS_FALLING = ? (exactly as it says)\n--------------------NUMBERS---------------------\nSPEED = ? (mutable, used to apply force in the \ndirection player wants)\nMAX_SPEED = 5.0 (the \"max\" speed, player can go \nabove, only matters for friction)\nACCELERATION = 5.0 (adds to speed when player is\nunder \"max\" speed, only applies when player is\nGROUNDED)\nDASH_SPEED = 15.0 (adds to the speed when called)\nJUMP_HEIGHT = 5.0 (how heigh the player can jump)\nFRICTION = 2.5 (increases by 1/5 of your speed \nwhen player is NOT accelerating, resets when \nplayer moves or is at 0 speed, only applies when\nplayer is ABOVE MAX_SPEED AND on ground)\nFRICTION_DELAY = 0.5 (how long on ground until\nfriction applies)\nGRAVITY = 2.5 (increases by .05 AFTER jumping \nevery .5 sec is finished, resets on first \ncollision with wall or grounded)\nWALL_JUMP_ANGLE = ? (reverses players view angle\nto wall to apply opposite when jumping to jump\nAWAY from wall)\nREMAINING_WALL_JUMPS = 3 (remove one per wall jump,\nif at 0 set CAN_WALL_JUMP to false else true, reset \nwhen ground collision)",
      "autoResize": true,
      "lineHeight": 1.25
    },
