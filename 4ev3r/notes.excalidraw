      "link": null,
      "locked": false,
      "text": "important keys:\nforward, backward, left, right, jump, dash\n\npress movement key (forward backward left right) to both:\naccelerate if on ground while under max speed, and apply your speed \nforce to that direction if not on ground, just apply speed in that\ndirection\n\nif colliding with wall and in air, stop gravity temp (1.0 sec) then \nstart reapplying gravity, but with the cap of 2.5\n\nto walljump: \ntake angle of player looking at the wall and use it to make them jump\naway from the wall (turn it by 180 and reverse for the calc, use double \nplayer default accel and normal jump height, player can chain jumps)\n\nto dash: just add that speed to player \nSPEED",
      "fontSize": 9.379669516780243,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "important keys:\nforward, backward, left, right, jump, dash\n\npress movement key (forward backward left right) to both:\naccelerate if on ground while under max speed, and apply your speed \nforce to that direction if not on ground, just apply speed in that\ndirection\n\nif colliding with wall and in air, stop gravity temp (1.0 sec) then \nstart reapplying gravity, but with the cap of 2.5\n\nto walljump: \ntake angle of player looking at the wall and use it to make them jump\naway from the wall (turn it by 180 and reverse for the calc, use double \nplayer default accel and normal jump height, player can chain jumps)\n\nto dash: just add that speed to player \nSPEED",
      "autoResize": true,
      "lineHeight": 1.25
    }
